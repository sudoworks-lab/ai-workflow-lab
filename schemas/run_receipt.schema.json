{
  "type": "object",
  "required": [
    "run_id",
    "task_type",
    "started_at",
    "finished_at",
    "task",
    "input",
    "expected_output",
    "artifacts",
    "checks",
    "risk",
    "review_points",
    "status",
    "summary",
    "next_actions"
  ],
  "properties": {
    "run_id": { "type": "string" },
    "task_type": { "type": "string" },
    "started_at": { "type": "string" },
    "finished_at": { "type": "string" },
    "task": {
      "type": "object",
      "required": ["goal", "scope"],
      "properties": {
        "goal": { "type": "string" },
        "scope": { "type": "array", "items": { "type": "string" } }
      }
    },
    "input": {
      "type": "object",
      "required": ["ref", "summary"],
      "properties": {
        "ref": { "type": "string" },
        "summary": { "type": "string" }
      }
    },
    "expected_output": {
      "type": "object",
      "required": ["artifacts", "acceptance_criteria"],
      "properties": {
        "artifacts": { "type": "array", "items": { "type": "string" } },
        "acceptance_criteria": { "type": "array", "items": { "type": "string" } }
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "kind", "change_summary"],
        "properties": {
          "path": { "type": "string" },
          "kind": { "type": "string" },
          "change_summary": { "type": "string" }
        }
      }
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "command", "result", "notes"],
        "properties": {
          "name": { "type": "string" },
          "command": { "type": "string" },
          "result": { "type": "string" },
          "notes": { "type": "string" }
        }
      }
    },
    "risk": {
      "type": "object",
      "required": ["level", "findings", "residual_risk"],
      "properties": {
        "level": { "type": "string" },
        "findings": { "type": "array", "items": { "type": "string" } },
        "residual_risk": { "type": "array", "items": { "type": "string" } }
      }
    },
    "review_points": { "type": "array", "items": { "type": "string" } },
    "status": { "type": "string" },
    "summary": { "type": "string" },
    "next_actions": { "type": "array", "items": { "type": "string" } }
  }
}
